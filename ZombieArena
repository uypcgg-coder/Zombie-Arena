local function FormatNumber(num)
	if num >= 1e12 then
		return string.format("%.2f", num / 1e12):gsub("%.?0+$", "") .. "T"
	elseif num >= 1e9 then
		return string.format("%.2f", num / 1e9):gsub("%.?0+$", "") .. "B"
	elseif num >= 1e6 then
		return string.format("%.2f", num / 1e6):gsub("%.?0+$", "") .. "M"
	elseif num >= 1e3 then
		return string.format("%.2f", num / 1e3):gsub("%.?0+$", "") .. "K"
	else
		return tostring(num)
	end
end

local function UpdateCredits()
	credits.Text = FormatNumber(creditValue.Value)
end

UpdateCredits()
creditValue.Changed:Connect(UpdateCredits)

